# =============================================================================
# .env_example
# =============================================================================
# Single source of truth for every environment variable understood by the
# SCA Tool Evaluation Framework. Copy this file to `.env`, replace the
# placeholder values, and source it before running any pipeline step:
#
#     cp .env_example .env
#     # edit .env and insert your real values
#     set -a && source .env && set +a
#
# Conventions used below
# -----------------------------------------------------------------------------
#   - Lines starting with `#` are comments.
#   - Variables that MUST be set before running the pipeline are marked
#     [REQUIRED]. All others are optional or have sensible defaults.
#   - Variables marked [DYNAMIC] are often overwritten at runtime by the
#     experiment / temporal runners; keep them commented out unless you
#     explicitly need to pin them.
#   - NEVER commit real tokens, credentials, or private URLs to git.
#     The repository's .gitignore already excludes `.env`.
#
# =============================================================================


# =============================================================================
# 1. PROJECT PATHS
# =============================================================================
# These variables define the root layout of the project on your machine.
# All derived output paths (experiments, reports, ground-truth builds) are
# resolved relative to CODEBASE.
# -----------------------------------------------------------------------------

# [REQUIRED]
# Absolute path to the checked-out project root (the directory that contains
# `pyproject.toml`, `src/`, `tools/`, etc.). Used by the experiment runner
# and as the base path for every derived directory below.
CODEBASE=/path/to/sca_tool_evaluation

# Build base directory. Holds generated artifacts (ground-truth datasets,
# SBOMs, reports, experiment runs). Safe to delete between runs;
# every pipeline step recreates what it needs.
CODEBASE_BUILD_PATH="${CODEBASE}/build"

# Report output directory. Convenience path used by some helper scripts
# to co-locate human-readable reports (LaTeX tables, PNG plots, TXT
# summaries). Individual scripts may still write elsewhere.
REPORT_PATH="${CODEBASE_BUILD_PATH}/reports"

# Root directory for experiment runs. The runner creates one subdirectory
# per RUN_ID (e.g. `${EXPERIMENT_PATH}/run_1/`, `run_2/`, ...).
EXPERIMENT_PATH="${CODEBASE_BUILD_PATH}/experiments"

# [DYNAMIC]
# In newer runner versions, the ground-truth build path is created
# dynamically per experiment / run / attempt and should NOT be pinned in
# `.env`. Leave this commented out unless you are running an older
# workflow that requires a fixed path.
# GROUND_TRUTH_BUILD_PATH="${CODEBASE_BUILD_PATH}/ground_truth"


# =============================================================================
# 2. API TOKENS AND CREDENTIALS
# =============================================================================
# Required only for the adapters and external services you actually use.
# Unused tokens can be left as the placeholder values.
# -----------------------------------------------------------------------------

# [REQUIRED for GitHub adapter and for ground-truth generation]
# GitHub personal access token. Needed for:
#   - the `github` adapter (GitHub Security Advisory Database queries)
#   - OSV / ecosystem metadata fetches that hit GitHub APIs
# Scopes: `public_repo` is sufficient for read-only advisory access.
# Create under: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token

# [REQUIRED for OSS Index adapter]
# OSS Index (Sonatype) API token.
# Obtain at: https://ossindex.sonatype.org/user/settings
OSSINDEX_TOKEN=your_ossindex_token

# [REQUIRED for OSS Index adapter]
# OSS Index account identifier (typically the e-mail used for registration).
OSSINDEX_USERNAME=your_ossindex_username

# [OPTIONAL for the NVD completeness diagnostic]
# NVD (NIST National Vulnerability Database) API key. The diagnostic works
# without it, but a key raises NVD's rate limit from 5 to 50 requests per 30 s,
# so runs over many CVEs are far faster. Request one at:
#   https://nvd.nist.gov/developers/request-an-api-key
# Used only by the standalone `evaluation.nvd_completeness.runner`; NVD is a
# side-by-side completeness diagnostic and is NOT part of EVAL_TOOLS or the
# `--tool` detection choices.
NVD_API_KEY=your_nvd_api_key

# [OPTIONAL] Transport tuning for the NVD completeness diagnostic. All have
# sensible defaults; override only if you hit NVD instability or want to pace
# requests differently. Read by `evaluation.adapters.nvd.NvdAdapter`.
#
#   NVD_MAX_RETRIES             Max attempts per CVE request before raising
#                               (default 4). A transport failure raises rather
#                               than being miscounted as "CVE absent".
#   NVD_RETRY_BACKOFF_S         Base backoff in seconds; grows per attempt and
#                               honors any `Retry-After` header (default 2.0).
#   NVD_MIN_REQUEST_INTERVAL_S  Min seconds between requests. Defaults to the
#                               rate-limit-derived pacing (0.6 s with a key,
#                               6.0 s anonymous); set 0 to disable pacing.
# NVD_MAX_RETRIES=4
# NVD_RETRY_BACKOFF_S=2.0
# NVD_MIN_REQUEST_INTERVAL_S=0.6


# =============================================================================
# 3. GROUND-TRUTH GENERATION - GLOBAL CONTROLS
# =============================================================================
# Parameters that shape the overall scope of ground-truth collection.
# -----------------------------------------------------------------------------

# Number of candidate packages / components considered per ecosystem.
# The collector applies `packages = packages[:SAMPLES]`. Setting SAMPLES
# higher than the package universe has no effect.
# Typical values: 100 (quick smoke test) ... 5000 (full-scale study).
SAMPLES=1000

# Publication window for version selection. Versions published outside
# [START_DATE, END_DATE] are excluded from the ground-truth dataset.
# Format: ISO-8601 date (YYYY-MM-DD).
START_DATE="2020-01-01"
END_DATE="2026-01-25"

# Space-separated list of ecosystems to include. Supported values:
#   pypi   - Python Package Index
#   npm    - Node.js package registry
#   maven  - Maven Central
#   nuget  - NuGet.org
# Order does not affect results but determines log / progress ordering.
ECOSYSTEMS="nuget maven pypi npm"

# Whether to apply post-hoc balancing across ecosystems. If `false`, the
# collected rows are kept as-is; if `true`, rows are down-sampled per
# ecosystem according to BALANCE_STRATEGY.
BALANCE=false

# Balancing strategy applied when BALANCE=true:
#   min     - down-sample all ecosystems to the count of the smallest one
#   median  - down-sample all ecosystems to the median count
BALANCE_STRATEGY="min"

# Optional seed for deterministic balancing and any random sub-sampling.
# Set to a fixed integer to reproduce published results exactly.
RANDOM_SEED=42


# =============================================================================
# 4. GROUND-TRUTH GENERATION - VERSION SAMPLING PER ECOSYSTEM
# =============================================================================
# Hard upper bound on the number of versions evaluated per package during
# collection. Higher values increase dataset size and API traffic.
# -----------------------------------------------------------------------------

# Maven: maximum number of versions per groupId:artifactId.
MAVEN_MAX_VERSIONS_PER_PACKAGE=10

# PyPI: maximum number of versions per package. Kept small by default
# because PyPI packages tend to have long release histories.
PYPI_MAX_VERSIONS_PER_PACKAGE=3

# npm: maximum number of versions per package.
NPM_MAX_VERSIONS_PER_PACKAGE=20

# NuGet: maximum number of versions per package.
NUGET_MAX_VERSIONS_PER_PACKAGE=20


# =============================================================================
# 5. GROUND-TRUTH GENERATION - VULNERABILITY SAMPLING
# =============================================================================
# Controls how many OSV matches per component version are retained and when
# collection stops.
# -----------------------------------------------------------------------------

# Maximum number of OSV entries retained per concrete component version.
# Example: if a version has 40 matched OSV entries and this is set to 10,
# only the first 10 entries from the OSV response are used.
MAX_OSV_ENTRIES_PER_COMPONENT=10

# Target total number of vulnerability rows per ecosystem. Used by some
# collectors as a soft target (see EARLY_STOP_ON_TARGET_VULNS below).
TARGET_VULNS_PER_ECOSYSTEM=250

# Early-stop switch for the per-ecosystem collector:
#   1 = stop once TARGET_VULNS_PER_ECOSYSTEM rows have been collected
#   0 = process every selected package regardless of the running count
# For diagnostic or publication-quality runs, prefer 0 (exhaustive).
EARLY_STOP_ON_TARGET_VULNS=1


# =============================================================================
# 6. TOOL SELECTION (EVALUATION)
# =============================================================================
# Controls which adapters the temporal runner executes.
# -----------------------------------------------------------------------------

# Space-separated list of tool identifiers.
# Supported identifiers (match `--tool` choices in evaluation.evaluate):
#   dtrack     - Dependency-Track (self-hosted instance required)
#   osv        - OSV.dev public API
#   github     - GitHub Security Advisory Database
#   snyk       - Snyk CLI (local binary required)
#   trivy      - Aqua Trivy CLI (local binary required)
#   oss-index  - Sonatype OSS Index API
# Example (full set):
#   EVAL_TOOLS="snyk oss-index github trivy dtrack"
EVAL_TOOLS="snyk dtrack"


# =============================================================================
# 7. DEPENDENCY-TRACK
# =============================================================================
# Required only if `dtrack` is included in EVAL_TOOLS.
# -----------------------------------------------------------------------------

# Base URL of the Dependency-Track API. Include the scheme and port.
# The API root is typically served at `/api/v1/...`.
DTRACK_URL=http://localhost:8081

# Dependency-Track API key. Create under:
#   Administration -> Access Management -> Teams -> (team) -> API Keys
# The key needs permissions to upload BOMs, read findings, and manage
# the project used by the evaluation runner.
DTRACK_API_KEY="your_dtrack_api_key"

# [DYNAMIC]
# Dependency-Track project UUID. In current runner versions the project
# is created or resolved dynamically per run, so this should usually be
# left empty. Only set this when you want to pin all runs to one project.
DTRACK_PROJECT_UUID=""

# [DYNAMIC]
# Project name used when the runner creates a dedicated DT project for
# a run. The runner typically derives this at runtime, e.g. `eval_<RUN_ID>`.
DTRACK_PROJECT_NAME=""

# [DYNAMIC]
# Project version used for runner-created DT projects. Defaults to "1.0"
# when omitted.
DTRACK_PROJECT_VERSION="1.0"


# =============================================================================
# 8. OSV
# =============================================================================

# Optional: path to a local OSV feed or dump. Only needed if you run
# against an offline OSV mirror instead of querying osv.dev over the
# network. Leave as-is (or comment out) for normal online use.
OSV_ROOT_PATH="/path/to/local/osv/vulnfeeds"


# =============================================================================
# 9. SNYK
# =============================================================================
# Required only if `snyk` is included in EVAL_TOOLS.
# -----------------------------------------------------------------------------

# Absolute path to the Snyk CLI binary. Some scripts fall back to
# `command -v snyk`, but pinning the path avoids PATH surprises.
# Authenticate once beforehand:
#   snyk auth
SNYK_BIN="/usr/local/bin/snyk"

# Wrapper script used by the evaluation pipeline to invoke the Snyk CLI
# with the correct flags (e.g. `snyk sbom test --experimental`).
SNYK_BASH_SCRIPT="${CODEBASE}/tools/evaluate_snyk.sh"


# =============================================================================
# 10. EXECUTION AND EXPERIMENT CONTROL
# =============================================================================

# Number of independent outer experiment runs performed by the temporal
# runner. Each run produces its own subdirectory under EXPERIMENT_PATH.
#   NUM_RUNS=1  -> only run_1
#   NUM_RUNS=5  -> run_1 ... run_5 (used for statistical significance)
NUM_RUNS=1

# Whether per-run artifacts should be archived into a compact bundle
# after each run. Not every script version enforces this flag, but it
# is read by the orchestration helpers.
ARCHIVE_RESULTS=true

# Report export switches. These are documented here for completeness;
# depending on the specific runner version they may be informational
# only, with every format always being produced.
EXPORT_LATEX=true
EXPORT_JSON=true
EXPORT_CSV=true

# Optional legacy progress-verbosity switch. Leave commented out unless
# a script you run explicitly expects it.
# EVAL_PROGRESS=2


# =============================================================================
# 11. SONARQUBE (OPTIONAL, CODE QUALITY)
# =============================================================================
# Only needed if you run `make sonar` to push the codebase, test coverage,
# and SBOM to a SonarQube instance. The base configuration lives in
# `sonar-project.properties`; only the host URL and the token are injected
# via these environment variables (never stored in the repo).
# -----------------------------------------------------------------------------

# Base URL of the SonarQube instance, e.g. https://sonar.example.com
# Include the scheme but no trailing path. Required by `make sonar`.
# SONAR_URL="https://sonar.example.com"

# SonarQube user or project analysis token. Create at:
#   <SONAR_URL>/account/security  (Generate Tokens section)
# Prefer a "Project Analysis Token" scoped to this project over a user
# token, and set a short expiration.
# SONAR_TOKEN="squ_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Prerequisite: the `sonar-scanner` CLI must be installed and on PATH.
# Installation options:
#   macOS (Homebrew):   brew install sonar-scanner
#   Linux / manual:     download from
#     https://docs.sonarsource.com/sonarqube-server/latest/analyzing-source-code/scanners/sonarscanner/
#     unpack, then either add <install>/bin to PATH or set SONAR_SCANNER
#     in the Makefile invocation (e.g. SONAR_SCANNER=/opt/sonar-scanner/bin/sonar-scanner make sonar).
# Verify with:
#   sonar-scanner --version

# Required pre-steps before `make sonar`:
#   make coverage              # produce build/coverage/coverage.xml (MANDATORY)
#   make sbom                  # produce build/sbom/sbom.json        (recommended)
#
# Typical invocation:
#   SONAR_URL=... SONAR_TOKEN=... make sonar
#
# `make sonar` refuses to run without coverage.xml and will warn if no SBOM
# is present; the path to both files is baked into sonar-project.properties.


# =============================================================================
# SUMMARY OF RUNTIME BEHAVIOR
# =============================================================================
# Directly consumed by the experiment runner:
#   CODEBASE, EXPERIMENT_PATH, NUM_RUNS, GITHUB_TOKEN, EVAL_TOOLS,
#   DTRACK_URL / DTRACK_API_KEY   (when dtrack is enabled)
#
# Consumed by the per-ecosystem ground-truth collectors:
#   SAMPLES, START_DATE, END_DATE, ECOSYSTEMS,
#   *_MAX_VERSIONS_PER_PACKAGE,
#   MAX_OSV_ENTRIES_PER_COMPONENT, TARGET_VULNS_PER_ECOSYSTEM,
#   EARLY_STOP_ON_TARGET_VULNS
#
# Typically overridden dynamically by newer runners:
#   GROUND_TRUTH_BUILD_PATH,
#   DTRACK_PROJECT_NAME, DTRACK_PROJECT_VERSION, DTRACK_PROJECT_UUID
# =============================================================================
